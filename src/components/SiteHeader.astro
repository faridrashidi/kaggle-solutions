---
import { siteConfig } from "../config/site";
import { getGithubRepositoryStats } from "../data/github";

const githubRepositoryStats = await getGithubRepositoryStats();
const githubStarsLabel = githubRepositoryStats.formattedStarCount;
const githubStarsDisplay = githubStarsLabel ?? "GitHub";
const githubAriaLabel =
  githubRepositoryStats.starCount !== null
    ? `GitHub repository with ${githubStarsLabel} stars`
    : "GitHub repository";
const [brandPrimary = siteConfig.title, ...brandSecondaryWords] =
  siteConfig.title.split(" ");
const brandSecondary = brandSecondaryWords.join(" ");
---

<header class="site-header">
  <div class="shell site-header__inner">
    <div class="site-header__spacer" aria-hidden="true"></div>
    <a class="brand" href="/" aria-label={siteConfig.title}>
      <span class="brand__text">
        <span class="brand__primary">{brandPrimary}</span>
        {
          brandSecondary && (
            <span class="brand__secondary">{brandSecondary}</span>
          )
        }
      </span>
    </a>
    <div class="site-header__actions">
      <button
        id="theme-toggle"
        class="theme-toggle"
        type="button"
        aria-label="Theme: system"
        title="Theme: system"
      >
        <svg
          id="system-icon"
          class="theme-toggle__icon is-active"
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <rect x="3" y="4" width="18" height="12" rx="2"></rect>
          <path d="M8 20h8"></path>
          <path d="M12 16v4"></path>
        </svg>
        <svg
          id="light-icon"
          class="theme-toggle__icon"
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <circle cx="12" cy="12" r="4"></circle>
          <path d="M12 2v2"></path>
          <path d="M12 20v2"></path>
          <path d="m4.93 4.93 1.41 1.41"></path>
          <path d="m17.66 17.66 1.41 1.41"></path>
          <path d="M2 12h2"></path>
          <path d="M20 12h2"></path>
          <path d="m6.34 17.66-1.41 1.41"></path>
          <path d="m19.07 4.93-1.41 1.41"></path>
        </svg>
        <svg
          id="dark-icon"
          class="theme-toggle__icon"
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"></path>
        </svg>
      </button>
      <a
        class="site-nav__link site-nav__link--external"
        href={siteConfig.repositoryUrl}
        target="_blank"
        rel="noreferrer"
        aria-label={githubAriaLabel}
      >
        <svg
          class="site-nav__github-icon"
          viewBox="0 0 16 16"
          fill="currentColor"
          role="presentation"
          aria-hidden="true"
        >
          <path
            d="M8 0C3.58 0 0 3.58 0 8a8 8 0 0 0 5.47 7.59c.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.5-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82A7.66 7.66 0 0 1 8 4.97c.68 0 1.37.09 2.01.26 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8Z"
          ></path>
        </svg>
        <span class="site-nav__stars" aria-hidden="true"
          >{githubStarsDisplay}</span
        >
      </a>
    </div>
  </div>
</header>

<script is:inline>
  const STORAGE_KEY = "theme-preference";
  const root = document.documentElement;
  const media = window.matchMedia("(prefers-color-scheme: dark)");
  const themeOrder = ["system", "light", "dark"];
  const themeToggle = document.getElementById("theme-toggle");
  const metaTheme = document.querySelector('meta[name="theme-color"]');
  const COLORS = { light: "#0f6d8c", dark: "#09131d" };

  const resolveTheme = (theme) =>
    theme === "system" ? (media.matches ? "dark" : "light") : theme;

  const getThemePreference = () => {
    try {
      return (
        localStorage.getItem(STORAGE_KEY) ||
        root.dataset.themePreference ||
        "system"
      );
    } catch {
      return root.dataset.themePreference || "system";
    }
  };

  const syncThemeToggle = (theme) => {
    document
      .getElementById("system-icon")
      ?.classList.toggle("is-active", theme === "system");
    document
      .getElementById("light-icon")
      ?.classList.toggle("is-active", theme === "light");
    document
      .getElementById("dark-icon")
      ?.classList.toggle("is-active", theme === "dark");

    if (themeToggle) {
      themeToggle.setAttribute("aria-label", `Theme: ${theme}`);
      themeToggle.setAttribute("title", `Theme: ${theme}`);
    }
  };

  const applyTheme = (theme) => {
    const resolvedTheme = resolveTheme(theme);
    root.dataset.themePreference = theme;
    root.dataset.theme = resolvedTheme;
    root.style.colorScheme = resolvedTheme;

    if (metaTheme) {
      metaTheme.setAttribute("content", COLORS[resolvedTheme]);
    }

    syncThemeToggle(theme);
  };

  const persistTheme = (theme) => {
    try {
      localStorage.setItem(STORAGE_KEY, theme);
    } catch {
      return;
    }
  };

  themeToggle?.addEventListener("click", () => {
    const currentTheme = getThemePreference();
    const currentIndex = themeOrder.indexOf(currentTheme);
    const nextTheme = themeOrder[(currentIndex + 1) % themeOrder.length];
    persistTheme(nextTheme);
    applyTheme(nextTheme);
  });

  media.addEventListener("change", () => {
    if (getThemePreference() === "system") {
      applyTheme("system");
    }
  });

  applyTheme(getThemePreference());
</script>
