---
import BaseLayout from "../layouts/BaseLayout.astro";

const title = "404: Page not found";
const description =
  "The page you were trying to reach is not in the Kaggle Solutions archive.";
---

<BaseLayout
  title={title}
  description={description}
  canonicalPath="/404"
  noIndex
>
  <section class="not-found">
    <div class="shell not-found__inner">
      <h1>That page is not in the archive.</h1>
      <p>
        The competition index lives on the homepage, and the curated resource
        pages stay under <code>/resources/*</code>.
      </p>
      <div class="hero__actions">
        <a class="hero-link hero-link--primary" href="/">Go back home</a>
        <a class="hero-link" href="/resources/symbols">Open the legend</a>
      </div>
    </div>
  </section>
</BaseLayout>
