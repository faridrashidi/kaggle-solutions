---
import CompetitionCard from "../components/CompetitionCard.astro";
import CompetitionRow from "../components/CompetitionRow.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import {
  competitionKinds,
  competitionStats,
  competitions,
  competitionYears,
} from "../data/competitions";
import { siteConfig } from "../config/site";

const resolveGithubRepositoryPath = (repositoryUrl: string) => {
  try {
    const repository = new URL(repositoryUrl);
    const segments = repository.pathname.replace(/^\/+|\/+$/g, "").split("/");

    if (segments.length >= 2) {
      return {
        owner: segments[0],
        repo: segments[1].replace(/\.git$/, ""),
      };
    }
  } catch {
    // Keep the hero stats as static labels if the repository URL is invalid.
  }

  return null;
};

const githubRepositoryPath = resolveGithubRepositoryPath(
  siteConfig.repositoryUrl,
);
const lazyPageSize = 10;
---

<BaseLayout
  title={siteConfig.title}
  description={siteConfig.description}
  canonicalPath="/"
>
  <section class="hero">
    <div class="shell hero__simple">
      <h1>Kaggle Solutions</h1>
      <p class="hero__lede">
        This is a list of almost all available solutions and ideas shared by top
        performers in the past Kaggle competitions. This list gets updated as
        soon as a new competition finishes. If you found it interesting, you may
        give a star or make a fork
      </p>
      <p class="hero__meta">
        Last updated <strong>{siteConfig.lastUpdated}</strong>.
      </p>

      <a
        id="github-repository-link"
        class="hero-github-card"
        href={siteConfig.repositoryUrl}
        target="_blank"
        rel="noreferrer"
        aria-label="GitHub repository statistics"
        data-owner={githubRepositoryPath?.owner}
        data-repo={githubRepositoryPath?.repo}
      >
        <span class="hero-github-card__brand" aria-hidden="true">
          <svg
            class="hero-github-card__icon"
            viewBox="0 0 16 16"
            fill="currentColor"
            role="presentation"
          >
            <path
              d="M8 0C3.58 0 0 3.58 0 8a8 8 0 0 0 5.47 7.59c.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.5-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82A7.66 7.66 0 0 1 8 4.97c.68 0 1.37.09 2.01.26 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8Z"
            ></path>
          </svg>
          <span>
            <strong>GitHub</strong>
            <span>Repository</span>
          </span>
        </span>
        <span class="hero-github-card__stats">
          <span class="hero-github-stat">
            <strong data-github-stars
              >{siteConfig.githubStatsFallback.stars}</strong
            >
            <span>stars</span>
          </span>
          <span class="hero-github-stat">
            <strong data-github-forks
              >{siteConfig.githubStatsFallback.forks}</strong
            >
            <span>forks</span>
          </span>
        </span>
      </a>
    </div>
  </section>

  <section class="overview-section">
    <div class="shell overview-simple">
      <ul class="overview-links">
        {
          siteConfig.resourceCards.map((card) => (
            <li>
              <a class="overview-links__link" href={card.href}>
                <strong>{card.title}</strong>
                <span>{card.summary}</span>
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <section class="explorer-section" id="competition-index">
    <div class="shell" data-competition-explorer data-page-size={lazyPageSize}>
      <div class="explorer-heading">
        <div>
          <h2>Competition index</h2>
        </div>
        <p class="explorer-heading__text">
          {competitionStats.total.toLocaleString()} competitions collected from
          {competitionStats.firstYear}-{competitionStats.latestYear}.
        </p>
      </div>

      <div class="explorer-toolbar">
        <label class="control control--search">
          <span class="control__label">Search</span>
          <input
            data-filter="q"
            id="competition-search"
            type="search"
            name="q"
            placeholder="Title, description, metric, team size, year, ranking..."
            autocomplete="off"
          />
        </label>

        <label class="control">
          <span class="control__label">Kind</span>
          <select data-filter="kind" name="kind">
            <option value="all">All kinds</option>
            {
              competitionKinds.map((kind) => (
                <option value={kind}>{kind}</option>
              ))
            }
          </select>
        </label>

        <label class="control">
          <span class="control__label">Year</span>
          <select data-filter="year" name="year">
            <option value="all">All years</option>
            {
              competitionYears.map((year) => (
                <option value={year}>{year}</option>
              ))
            }
          </select>
        </label>

        <label class="control">
          <span class="control__label">Status</span>
          <select data-filter="status" name="status">
            <option value="all">All statuses</option>
            <option value="curated">Curated</option>
            <option value="missing">Missing</option>
            <option value="hot">Hot</option>
          </select>
        </label>

        <label class="control">
          <span class="control__label">Sort</span>
          <select data-filter="sort" name="sort">
            <option value="newest">Newest first</option>
            <option value="oldest">Oldest first</option>
            <option value="most-solutions">Most links</option>
            <option value="largest-teams">Largest fields</option>
          </select>
        </label>

        <p
          class="explorer-meta__count explorer-toolbar__count"
          data-results-count
        >
          {competitionStats.total.toLocaleString()} competitions in the archive.
        </p>
      </div>

      <div class="desktop-table">
        <table class="competition-table">
          <colgroup>
            <col class="competition-table__col competition-table__col--main" />
            <col
              class="competition-table__col competition-table__col--details"
            />
            <col
              class="competition-table__col competition-table__col--solutions"
            />
            <col
              class="competition-table__col competition-table__col--status"
            />
          </colgroup>
          <thead>
            <tr>
              <th scope="col">Competition</th>
              <th scope="col">Details</th>
              <th scope="col">Solutions</th>
              <th scope="col">Status</th>
            </tr>
          </thead>
          <tbody data-table-body>
            {
              competitions.map((competition) => (
                <CompetitionRow competition={competition} />
              ))
            }
          </tbody>
        </table>
      </div>

      <div class="competition-grid" data-card-grid>
        {
          competitions.map((competition) => (
            <CompetitionCard competition={competition} />
          ))
        }
      </div>

      <div class="load-more" data-load-more hidden>
        <button
          class="hero-link load-more__button"
          type="button"
          data-load-more-button
        >
          Load more
        </button>
      </div>

      <div class="empty-state" data-empty-state hidden>
        <p>No competitions match the current filters.</p>
        <button
          class="hero-link hero-link--primary"
          type="button"
          data-clear-filters
        >
          Clear filters
        </button>
      </div>
    </div>
  </section>

  <script is:inline>
    (() => {
      const githubRepositoryLink = document.getElementById(
        "github-repository-link",
      );

      if (!githubRepositoryLink) {
        return;
      }

      const { owner, repo } = githubRepositoryLink.dataset;

      if (!owner || !repo) {
        return;
      }

      const githubStarTargets = githubRepositoryLink.querySelectorAll(
        "[data-github-stars]",
      );
      const githubForkTargets = githubRepositoryLink.querySelectorAll(
        "[data-github-forks]",
      );
      const formatter = new Intl.NumberFormat("en-US");

      const syncGithubStats = async () => {
        try {
          const response = await fetch(
            `https://api.github.com/repos/${owner}/${repo}`,
            {
              cache: "no-store",
              headers: {
                Accept: "application/vnd.github+json",
              },
            },
          );

          if (!response.ok) {
            return;
          }

          const repository = await response.json();
          const starCount = repository?.stargazers_count;
          const forkCount = repository?.forks_count;

          if (typeof starCount !== "number" || typeof forkCount !== "number") {
            return;
          }

          const formattedStarCount = formatter.format(starCount);
          const formattedForkCount = formatter.format(forkCount);

          githubStarTargets.forEach((target) => {
            target.textContent = formattedStarCount;
          });
          githubForkTargets.forEach((target) => {
            target.textContent = formattedForkCount;
          });
          githubRepositoryLink.setAttribute(
            "aria-label",
            `GitHub repository with ${formattedStarCount} stars and ${formattedForkCount} forks`,
          );
        } catch {
          // Keep the fallback numbers when the GitHub API is unavailable.
        }
      };

      void syncGithubStats();
    })();
  </script>

  <script is:inline>
    (() => {
      const root = document.querySelector("[data-competition-explorer]");

      if (!root) {
        return;
      }

      const searchInput = root.querySelector("[data-filter='q']");
      const kindSelect = root.querySelector("[data-filter='kind']");
      const yearSelect = root.querySelector("[data-filter='year']");
      const statusSelect = root.querySelector("[data-filter='status']");
      const sortSelect = root.querySelector("[data-filter='sort']");
      const resultsCount = root.querySelector("[data-results-count]");
      const emptyState = root.querySelector("[data-empty-state]");
      const clearFiltersButton = root.querySelector("[data-clear-filters]");
      const tableBody = root.querySelector("[data-table-body]");
      const cardGrid = root.querySelector("[data-card-grid]");
      const loadMore = root.querySelector("[data-load-more]");
      const loadMoreButton = root.querySelector("[data-load-more-button]");
      const configuredPageSize = Number.parseInt(
        root.dataset.pageSize ?? "20",
        10,
      );
      const pageSize =
        Number.isFinite(configuredPageSize) && configuredPageSize > 0
          ? configuredPageSize
          : 20;
      const rowElements = Array.from(
        root.querySelectorAll("[data-competition-row]"),
      );
      const cardElements = Array.from(
        root.querySelectorAll("[data-competition-card]"),
      );

      const cardById = new Map(
        cardElements.map((card) => [card.dataset.id, card]),
      );

      const records = rowElements.map((row) => {
        const card = cardById.get(row.dataset.id);

        return {
          id: row.dataset.id ?? "",
          row,
          card,
          search: row.dataset.search ?? "",
          kind: row.dataset.kind ?? "",
          year: row.dataset.year ?? "",
          status: row.dataset.status ?? "",
          isHot: row.dataset.hot === "true",
          number: Number.parseInt(row.dataset.number ?? "0", 10),
          teamCount: Number.parseInt(row.dataset.teamCount ?? "-1", 10),
          solutionCount: Number.parseInt(row.dataset.solutionCount ?? "0", 10),
        };
      });
      let matchingRecords = [];
      let visibleLimit = pageSize;

      const validKinds = new Set(
        Array.from(kindSelect.options).map((option) => option.value),
      );
      const validYears = new Set(
        Array.from(yearSelect.options).map((option) => option.value),
      );
      const validStatuses = new Set(
        Array.from(statusSelect.options).map((option) => option.value),
      );
      const validSorts = new Set(
        Array.from(sortSelect.options).map((option) => option.value),
      );

      function currentState() {
        return {
          q: searchInput.value.trim().toLowerCase(),
          kind: kindSelect.value,
          year: yearSelect.value,
          status: statusSelect.value,
          sort: sortSelect.value,
        };
      }

      function syncControlsFromUrl() {
        const params = new URLSearchParams(window.location.search);
        const q = params.get("q") ?? "";
        const kind = params.get("kind") ?? "all";
        const year = params.get("year") ?? "all";
        const status = params.get("status") ?? "all";
        const sort = params.get("sort") ?? "newest";

        searchInput.value = q;
        kindSelect.value = validKinds.has(kind) ? kind : "all";
        yearSelect.value = validYears.has(year) ? year : "all";
        statusSelect.value = validStatuses.has(status) ? status : "all";
        sortSelect.value = validSorts.has(sort) ? sort : "newest";
      }

      function updateUrl(state) {
        const params = new URLSearchParams();

        if (state.q) params.set("q", state.q);
        if (state.kind !== "all") params.set("kind", state.kind);
        if (state.year !== "all") params.set("year", state.year);
        if (state.status !== "all") params.set("status", state.status);
        if (state.sort !== "newest") params.set("sort", state.sort);

        const nextUrl = `${window.location.pathname}${
          params.toString() ? `?${params.toString()}` : ""
        }${window.location.hash}`;

        window.history.replaceState({}, "", nextUrl);
      }

      function escapeRegExp(value) {
        return value.replace(/[.*+?^${}()|[\]\\]/g, "\\$&");
      }

      function isOrdinalPlaceQuery(query) {
        return /^\d+(st|nd|rd|th)\s+place$/i.test(query);
      }

      function matchesSearch(record, query) {
        if (!query) {
          return true;
        }

        if (isOrdinalPlaceQuery(query)) {
          const exactPhrasePattern = new RegExp(
            `(^|[^a-z0-9])${escapeRegExp(query)}($|[^a-z0-9])`,
            "i",
          );

          return exactPhrasePattern.test(record.search);
        }

        return record.search.includes(query);
      }

      function matches(record, state) {
        const searchMatches = matchesSearch(record, state.q);
        const kindMatches = state.kind === "all" || record.kind === state.kind;
        const yearMatches = state.year === "all" || record.year === state.year;

        let statusMatches = true;

        if (state.status === "curated") {
          statusMatches = record.status === "curated";
        } else if (state.status === "missing") {
          statusMatches = record.status === "missing";
        } else if (state.status === "hot") {
          statusMatches = record.isHot;
        }

        return searchMatches && kindMatches && yearMatches && statusMatches;
      }

      function compareRecords(left, right, sort) {
        if (sort === "oldest") {
          return left.number - right.number;
        }

        if (sort === "most-solutions") {
          if (right.solutionCount !== left.solutionCount) {
            return right.solutionCount - left.solutionCount;
          }

          return right.number - left.number;
        }

        if (sort === "largest-teams") {
          if (right.teamCount !== left.teamCount) {
            return right.teamCount - left.teamCount;
          }

          return right.number - left.number;
        }

        return right.number - left.number;
      }

      function detachRecord(record) {
        record.row.remove();
        if (record.card) {
          record.card.remove();
        }
      }

      function updateResultsCount(totalMatches, shownCount) {
        if (totalMatches === 0) {
          resultsCount.textContent =
            "No competitions match the current filters.";
          return;
        }

        if (totalMatches === records.length && shownCount === records.length) {
          resultsCount.textContent = `${records.length.toLocaleString()} competitions in the archive.`;
          return;
        }

        if (totalMatches === records.length) {
          resultsCount.textContent = `Showing ${shownCount.toLocaleString()} of ${records.length.toLocaleString()} competitions.`;
          return;
        }

        resultsCount.textContent = `Showing ${shownCount.toLocaleString()} of ${totalMatches.toLocaleString()} matching competitions.`;
      }

      function renderRecords() {
        const shownCount = Math.min(visibleLimit, matchingRecords.length);
        const visibleRecords = matchingRecords.slice(0, shownCount);
        const tableFragment = document.createDocumentFragment();
        const cardFragment = document.createDocumentFragment();

        records.forEach(detachRecord);

        visibleRecords.forEach((record) => {
          record.row.hidden = false;
          tableFragment.appendChild(record.row);
          if (record.card) {
            record.card.hidden = false;
            cardFragment.appendChild(record.card);
          }
        });

        tableBody.appendChild(tableFragment);
        cardGrid.appendChild(cardFragment);

        updateResultsCount(matchingRecords.length, shownCount);

        emptyState.hidden = matchingRecords.length !== 0;
        if (loadMore) {
          loadMore.hidden = shownCount >= matchingRecords.length;
        }
        if (loadMoreButton) {
          loadMoreButton.disabled = shownCount >= matchingRecords.length;
        }
      }

      function loadNextRecords() {
        if (visibleLimit >= matchingRecords.length) {
          return;
        }

        visibleLimit = Math.min(
          visibleLimit + pageSize,
          matchingRecords.length,
        );
        renderRecords();
      }

      function applyFilters(updateLocation) {
        const state = currentState();

        visibleLimit = pageSize;
        matchingRecords = records
          .filter((record) => matches(record, state))
          .sort((left, right) => compareRecords(left, right, state.sort));

        renderRecords();

        if (updateLocation) {
          updateUrl(state);
        }
      }

      function resetFilters() {
        searchInput.value = "";
        kindSelect.value = "all";
        yearSelect.value = "all";
        statusSelect.value = "all";
        sortSelect.value = "newest";
        applyFilters(true);
      }

      function isTypingTarget(target) {
        if (!(target instanceof HTMLElement)) {
          return false;
        }

        if (target.isContentEditable) {
          return true;
        }

        return ["INPUT", "TEXTAREA", "SELECT"].includes(target.tagName);
      }

      [searchInput, kindSelect, yearSelect, statusSelect, sortSelect].forEach(
        (control) => {
          control.addEventListener("input", () => applyFilters(true));
          control.addEventListener("change", () => applyFilters(true));
        },
      );

      clearFiltersButton.addEventListener("click", resetFilters);
      loadMoreButton?.addEventListener("click", loadNextRecords);

      if ("IntersectionObserver" in window && loadMore) {
        const loadMoreObserver = new IntersectionObserver(
          (entries) => {
            if (entries.some((entry) => entry.isIntersecting)) {
              loadNextRecords();
            }
          },
          { rootMargin: "420px 0px" },
        );

        loadMoreObserver.observe(loadMore);
      }

      document.addEventListener("keydown", (event) => {
        if (
          event.key === "/" &&
          !event.metaKey &&
          !event.ctrlKey &&
          !event.altKey &&
          !isTypingTarget(document.activeElement)
        ) {
          event.preventDefault();
          searchInput.focus();
          searchInput.select();
        }
      });

      window.addEventListener("popstate", () => {
        syncControlsFromUrl();
        applyFilters(false);
      });

      syncControlsFromUrl();
      applyFilters(false);
    })();
  </script>
</BaseLayout>
